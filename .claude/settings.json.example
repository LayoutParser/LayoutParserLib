{
  "//": "Template recomendado do harness. Para ativar: copie para .claude/settings.json e remova as chaves // de comentário (JSON não aceita comentários).",
  "//language": "Responde ao usuário em português.",
  "language": "portuguese",

  "//permissions": "Allowlist de comandos seguros para reduzir prompts. Ajuste à vontade.",
  "permissions": {
    "allow": [
      "Bash(msbuild:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet restore:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(diff:*)",
      "Read",
      "Grep",
      "Glob"
    ]
  },

  "//hooks": "Hook NÃO-BLOQUEANTE que lembra a autoridade de push e o efeito de deploy em cascata. Remova este bloco para desativar.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/git-push-advisory.cjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
